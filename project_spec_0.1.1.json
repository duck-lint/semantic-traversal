{
  "metadata": {
    "id": "project_spec.json",
    "authority": "global",
    "last_update": "2026-06-18"
  },
  "system_description": "Conversational inputs trigger state_perturbations that activate data_representations and perform projection, traversal, retrieval, and inference synthesis operations",
  "system_design": {
    "runtime_flow": [
      {
        "id": 1,
        "process": "receive_user_input",
        "description": "User enters a message into a conversation_thread.",
        "operational_boundaries": [
          "UI",
          "conversation_thread"
        ],
        "input": [
          "user_input",
          "thread_id"
        ],
        "output": [
          "pending_state_perturbation"
        ]
      },
      {
        "id": 2,
        "process": "load_thread_state",
        "description": "Runtime loads the current materialized thread_state from the conversation_thread.",
        "operational_boundaries": [
          "conversation_thread",
          "thread_ledger",
          "thread_state"
        ],
        "input": [
          "thread_id",
          "latest_thread_state_hash"
        ],
        "output": [
          "prior_thread_state",
          "parent_perturbation_hash"
        ]
      },
      {
        "id": 3,
        "process": "semantic_context_extraction",
        "description": "User input is parsed in isolation, then salted with prior_thread_state to project the semantic target for this perturbation.",
        "operational_boundaries": [
          "conversation_thread",
          "state_perturbation"
        ],
        "input": [
          "user_input",
          "prior_thread_state"
        ],
        "suboperations": [
          "extract_user_input_semantic_units",
          "extract_contextual_salt_from_prior_thread_state",
          "form_edges_between_user_input_and_contextual_salt",
          "project_semantic_coverage_target"
        ],
        "output": [
          "perturbation_semantic_graph",
          "semantic_coverage_target"
        ]
      },
      {
        "id": 4,
        "process": "latent_space_activation",
        "description": "Semantic targets activate candidate regions of latent_space across available data representations.",
        "operational_boundaries": [
          "state_perturbation",
          "latent_space"
        ],
        "input": [
          "perturbation_semantic_graph",
          "semantic_coverage_target",
          "latent_space"
        ],
        "suboperations": [
          "activate_vector_regions",
          "activate_lexical_matches",
          "activate_graph_neighborhoods",
          "activate_primary_corpus_candidates",
          "activate_synthetic_node_candidates"
        ],
        "output": [
          "activated_semantic_regions"
        ]
      },
      {
        "id": 5,
        "process": "semantic_traversal",
        "description": "Activated regions are expanded into candidate neighborhoods and organized into a traversal manifest.",
        "operational_boundaries": [
          "state_perturbation",
          "latent_space"
        ],
        "input": [
          "activated_semantic_regions",
          "semantic_coverage_target"
        ],
        "suboperations": [
          "neighbor_identification",
          "graph_edge_expansion",
          "metadata_projection",
          "candidate_ranking",
          "coverage_guided_expansion"
        ],
        "output": [
          "semantic_traversal_manifest"
        ]
      },
      {
        "id": 6,
        "process": "retrieval_packet_assembly",
        "description": "Concrete content is retrieved from latent_space using the semantic_traversal_manifest.",
        "operational_boundaries": [
          "state_perturbation",
          "latent_space"
        ],
        "input": [
          "semantic_traversal_manifest"
        ],
        "suboperations": [
          "retrieve_chunk_text",
          "retrieve_note_metadata",
          "retrieve_graph_context",
          "retrieve_source_paths",
          "retrieve_synthetic_node_context"
        ],
        "output": [
          "retrieval_packet"
        ]
      },
      {
        "id": 7,
        "process": "retrieval_coverage_evaluation",
        "description": "Retrieved material is checked against the semantic_coverage_target before synthesis.",
        "operational_boundaries": [
          "state_perturbation"
        ],
        "input": [
          "semantic_coverage_target",
          "semantic_traversal_manifest",
          "retrieval_packet"
        ],
        "suboperations": [
          "evaluate_retrieval_sufficiency",
          "identify_missing_regions",
          "loop_to_traversal_if_required_and_budget_available",
          "record_coverage_limits"
        ],
        "output": [
          "coverage_report",
          "approved_retrieval_packet"
        ]
      },
      {
        "id": 8,
        "process": "synthesis_context_assembly",
        "description": "Runtime assembles the fresh LLM call context from user_input, prior_thread_state, traversal, retrieval, and coverage artifacts.",
        "operational_boundaries": [
          "state_perturbation",
          "LLM_call_boundary"
        ],
        "input": [
          "user_input",
          "prior_thread_state",
          "perturbation_semantic_graph",
          "semantic_coverage_target",
          "semantic_traversal_manifest",
          "approved_retrieval_packet",
          "coverage_report"
        ],
        "output": [
          "synthesis_context_packet"
        ]
      },
      {
        "id": 9,
        "process": "llm_synthesis",
        "description": "A fresh LLM call produces the user-facing response from the synthesis_context_packet.",
        "operational_boundaries": [
          "LLM_call_boundary"
        ],
        "input": [
          "synthesis_context_packet"
        ],
        "suboperations": [
          "generate_user_facing_response",
          "identify_optional_synthetic_node_candidate",
          "preserve_retrieval_basis"
        ],
        "output": [
          "assistant_response",
          "optional_synthetic_node_candidate"
        ]
      },
      {
        "id": 10,
        "process": "thread_state_delta_projection",
        "description": "Runtime materializes the next thread_state from the prior state, user input, perturbation artifacts, and assistant response.",
        "operational_boundaries": [
          "conversation_thread",
          "thread_state",
          "thread_ledger"
        ],
        "input": [
          "prior_thread_state",
          "user_input",
          "perturbation_semantic_graph",
          "semantic_traversal_manifest",
          "retrieval_packet",
          "coverage_report",
          "assistant_response"
        ],
        "output": [
          "next_thread_state",
          "state_delta"
        ]
      },
      {
        "id": 11,
        "process": "append_thread_ledger_record",
        "description": "Runtime appends a hash-chained perturbation record to the thread_ledger.",
        "operational_boundaries": [
          "thread_ledger"
        ],
        "input": [
          "parent_perturbation_hash",
          "prior_thread_state_hash",
          "user_input_hash",
          "perturbation_artifact_hashes",
          "assistant_response_hash",
          "state_delta_hash",
          "next_thread_state_hash"
        ],
        "output": [
          "state_perturbation_record",
          "state_perturbation_hash"
        ]
      },
      {
        "id": 12,
        "process": "optional_synthetic_node_promotion",
        "description": "Selected synthesis output may be intentionally promoted back into latent_space.",
        "operational_boundaries": [
          "conversation_thread",
          "latent_space"
        ],
        "input": [
          "optional_synthetic_node_candidate",
          "assistant_response",
          "retrieval_packet",
          "semantic_traversal_manifest",
          "state_perturbation_hash"
        ],
        "suboperations": [
          "write_markdown_note_if_promoted",
          "chunk_promoted_node",
          "index_lexically",
          "embed_vector",
          "write_graph_provenance_edges"
        ],
        "output": [
          "optional_promoted_synthetic_node",
          "latent_space_update_record"
        ]
      }
    ],
    "operational_boundaries": {
      "latent_space": {
        "description": "Present, potential, inactive data_representations available for activation into active_state",
        "components": {
          "primary_corpus": {
            "description": "A durable copy of the full Obsidian vault content available to the system",
            "content": [
              "personal notes",
              "scanned novels and source texts",
              "any other content the user intentionally places in the latent_space"
            ],
            "structure": [
              ".md notes in an Obsidian vault",
              "file structure and path topology are treated as semantically meaningful",
              "note frontmatter is treated as semantic metadata",
              "wiki links are treated as graph edges while notes are nodes",
              "raw source files remain available as original-context references for retrieval and provenance"
            ]
          },
          "corpus_nodes": {
            "description": "Derived semantic chunks produced from the primary_corpus",
            "content": [
              "primary_corpus"
            ],
            "structure": [
              "chunks are broken down by Markdown structure",
              "chunks preserve section ordinals",
              "chunks retain references to note frontmatter",
              "chunks retain references to note path topology",
              "chunks retain references to source note identity",
              "chunk_id = stable identifier derived from note identity + section ordinal + optional content hash"
            ]
          },
          "vector_index_surface": {
            "description": "Embedding-backed representation of corpus_nodes and promoted synthetic_nodes",
            "content": [
              "corpus_nodes",
              "promoted synthetic_nodes"
            ],
            "structure": [
              "supports semantic similarity search",
              "supports contextual neighbor identification",
              "supports activation of candidate semantic regions",
              "each vector record must retain linkage to source chunk_id and source note identity",
              "index backend remains implementation-flexible during early prototype"
            ]
          },
          "lexical_index_surface": {
            "description": "Lexical search representation of corpus_nodes and promoted synthetic_nodes",
            "content": [
              "corpus_nodes",
              "promoted synthetic_nodes"
            ],
            "structure": [
              "supports keyword search",
              "supports exact phrase matching",
              "supports hybrid retrieval alongside vector search",
              "lexical index must support retrieval over chunk text and selected metadata",
              "index backend remains implementation-flexible during early prototype"
            ]
          },
          "graph_layer": {
            "description": "Relation surface initially derived from Obsidian-native structure",
            "nodes": [
              "primary_corpus_notes",
              "corpus_nodes",
              "synthetic_nodes",
              "selected frontmatter values",
              "tags"
            ],
            "edges": [
              "wikilinks",
              "note_contains_chunk",
              "chunk_derived_from_note",
              "note_has_tag",
              "note_has_frontmatter_value",
              "synthetic_node_derived_from_thread",
              "synthetic_node_derived_from_sources"
            ],
            "structure": [
              "initial graph extraction should be scriptable from Obsidian vault structure",
              "wiki links provide first-pass note-to-note edges",
              "selected frontmatter fields may be projected into graph nodes and edges",
              "synthetic_nodes add provenance edges when promoted"
            ]
          },
          "synthetic_nodes": {
            "description": "Persisted synthesis artifacts created from conversational perturbations and promoted back into the data substrate",
            "content": [
              "conversation snippet preserving local context",
              "selected message or synthesis chunk"
            ],
            "structure": [
              "written .md note in primary_corpus with frontmatter_tag identification",
              "indexed chunk",
              "lexical record",
              "stored vector embedding",
              "graph provenance edges"
            ],
            "provenance": [
              "originating_thread_id",
              "originating_message_id or turn_id",
              "source_user_input",
              "source_synthesis_output",
              "source_retrieval_packet",
              "source_traversal_manifest",
              "created_at",
              "promotion_reason or promotion_mode"
            ]
          }
        }
      },
      "chunk_embed_store": {
        "description": "Ingestion and indexing boundary that converts user-provided content into latent_space data_representations",
        "components": [
          "semantic chunking script",
          "frontmatter extraction",
          "path topology extraction",
          "chunk_id generation",
          "embedding script",
          "lexical indexing script",
          "graph extraction script",
          "routing of produced artifacts into latent_space"
        ],
        "input": [
          "Markdown content",
          "Obsidian vault structure",
          "frontmatter metadata",
          "wiki links",
          "promoted synthetic_nodes"
        ],
        "output": [
          "corpus_nodes",
          "vector_index_surface records",
          "lexical_index_surface records",
          "graph_layer nodes",
          "graph_layer edges",
          "latent_space update record"
        ]
      },
      "user_input": {
        "description": "The user message or request that provides immediate, contextually semantic pressure triggering a state_perturbation",
        "components": [
          "UI surface for text entry",
          "raw user text",
          "semantic_context_extraction",
          "semantic_context_benchmark"
        ],
        "input": [
          "user text"
        ],
        "output": [
          "pending user_input event",
          "candidate semantic units",
          "initial perturbation pressure"
        ]
      },
      "conversation_thread": {
        "description": "Persistent UX and process container that gives fresh LLM calls conversational continuity",
        "components": [
          "thread_id",
          "visible transcript",
          "current thread_state pointer",
          "thread_ledger pointer",
          "current branch pointer if branching is later supported",
          "thread metadata"
        ],
        "input": [
          "user_input",
          "assistant_response",
          "thread_state_delta_projection",
          "state_perturbation_record"
        ],
        "output": [
          "prior_thread_state",
          "visible conversation continuity",
          "latest_thread_state_hash",
          "parent_perturbation_hash"
        ]
      },
      "thread_ledger": {
        "description": "Append-only, hash-chained sequence of state_perturbation records for a conversation_thread",
        "components": [
          "thread_id",
          "turn_id",
          "parent_perturbation_hash",
          "prior_thread_state_hash",
          "user_input_hash",
          "semantic_context_packet_hash",
          "semantic_traversal_manifest_hash",
          "retrieval_packet_hash",
          "coverage_report_hash",
          "assistant_response_hash",
          "state_delta_hash",
          "next_thread_state_hash",
          "state_perturbation_hash"
        ],
        "input": [
          "parent_perturbation_hash",
          "prior_thread_state_hash",
          "user_input_hash",
          "perturbation_artifact_hashes",
          "assistant_response_hash",
          "state_delta_hash",
          "next_thread_state_hash"
        ],
        "output": [
          "state_perturbation_record",
          "state_perturbation_hash",
          "auditable thread continuity"
        ]
      },
      "thread_state": {
        "description": "Current materialized projection of the thread_ledger used to hydrate the next fresh LLM call",
        "components": [
          "active concepts",
          "recent semantic trajectory",
          "current user goals",
          "open questions",
          "active constraints",
          "relevant prior distinctions",
          "recent retrieval anchors",
          "current semantic attractors",
          "conversation summary",
          "latest_thread_state_hash"
        ],
        "input": [
          "prior_thread_state",
          "state_delta",
          "assistant_response",
          "perturbation artifacts"
        ],
        "output": [
          "prior_thread_state for next state_perturbation",
          "contextual_salt for semantic_context_extraction",
          "state continuity for synthesis_context_assembly"
        ]
      },
      "state_perturbation": {
        "description": "One turn transition from prior_thread_state to next_thread_state, triggered by user_input",
        "components": [
          "semantic_context_extraction",
          "semantic_context_benchmark",
          "latent_space_activation",
          "semantic_traversal",
          "retrieval_packet_assembly",
          "retrieval_coverage_evaluation",
          "synthesis_context_assembly",
          "llm_synthesis",
          "thread_state_delta_projection",
          "append_thread_ledger_record",
          "optional_synthetic_node_promotion"
        ],
        "input": [
          "user_input",
          "prior_thread_state",
          "parent_perturbation_hash",
          "latent_space"
        ],
        "output": [
          "assistant_response",
          "next_thread_state",
          "state_delta",
          "state_perturbation_record",
          "state_perturbation_hash",
          "optional synthetic_node_candidate"
        ]
      },
      "semantic_context_extraction": {
        "description": "Operation that parses user_input in isolation, then hydrates it with prior_thread_state to project the semantic target for this perturbation",
        "components": [
          "extract_user_input_semantic_units",
          "extract_contextual_salt_from_prior_thread_state",
          "form_edges_between_user_input_and_contextual_salt",
          "project_semantic_coverage_target"
        ],
        "input": [
          "user_input",
          "prior_thread_state"
        ],
        "output": [
          "perturbation_nodes",
          "contextual_salt_nodes",
          "perturbation_semantic_graph",
          "semantic_coverage_target"
        ]
      },
      "semantic_context_benchmark": {
        "description": "Coverage target that estimates which semantic region must be activated before retrieval and synthesis can proceed",
        "components": [
          "perturbation_semantic_graph",
          "semantic_coverage_target",
          "candidate region requirements",
          "coverage threshold or heuristic",
          "retrieval expansion budget"
        ],
        "input": [
          "perturbation_nodes",
          "contextual_salt_nodes",
          "prior_thread_state",
          "user_input"
        ],
        "output": [
          "semantic_coverage_target",
          "coverage constraints",
          "initial traversal requirements"
        ]
      },
      "latent_space_activation": {
        "description": "Operation that activates candidate regions of latent_space across available data_representations",
        "components": [
          "activate_vector_regions",
          "activate_lexical_matches",
          "activate_graph_neighborhoods",
          "activate_primary_corpus_candidates",
          "activate_synthetic_node_candidates"
        ],
        "input": [
          "perturbation_semantic_graph",
          "semantic_coverage_target",
          "latent_space"
        ],
        "output": [
          "activated_semantic_regions",
          "candidate attractor regions"
        ]
      },
      "semantic_traversal": {
        "description": "Operation that expands activated semantic regions into candidate neighborhoods and organizes them into a traversal manifest",
        "components": [
          "neighbor_identification",
          "graph_edge_expansion",
          "metadata_projection",
          "candidate_ranking",
          "coverage_guided_expansion",
          "semantic_traversal_manifest_generation"
        ],
        "input": [
          "activated_semantic_regions",
          "semantic_coverage_target",
          "latent_space"
        ],
        "output": [
          "semantic_traversal_manifest"
        ]
      },
      "retrieval_packet_assembly": {
        "description": "Operation that retrieves concrete content from latent_space using the semantic_traversal_manifest",
        "components": [
          "retrieve_chunk_text",
          "retrieve_note_metadata",
          "retrieve_graph_context",
          "retrieve_source_paths",
          "retrieve_raw_markdown_spans_if_required",
          "retrieve_synthetic_node_context"
        ],
        "input": [
          "semantic_traversal_manifest",
          "latent_space"
        ],
        "output": [
          "retrieval_packet"
        ]
      },
      "retrieval_coverage_evaluation": {
        "description": "Operation that checks retrieved material against semantic_coverage_target before synthesis",
        "components": [
          "evaluate_retrieval_sufficiency",
          "identify_missing_regions",
          "loop_to_traversal_if_required_and_budget_available",
          "record_coverage_limits"
        ],
        "input": [
          "semantic_coverage_target",
          "semantic_traversal_manifest",
          "retrieval_packet"
        ],
        "output": [
          "coverage_report",
          "approved_retrieval_packet",
          "optional traversal_loop_request"
        ]
      },
      "synthesis_context_assembly": {
        "description": "Boundary where runtime packages the fresh LLM call context from thread continuity, semantic extraction, traversal, retrieval, and coverage artifacts",
        "components": [
          "system instructions",
          "current user_input",
          "prior_thread_state",
          "perturbation_semantic_graph",
          "semantic_coverage_target",
          "semantic_traversal_manifest",
          "approved_retrieval_packet",
          "coverage_report",
          "output requirements"
        ],
        "input": [
          "user_input",
          "prior_thread_state",
          "perturbation_semantic_graph",
          "semantic_coverage_target",
          "semantic_traversal_manifest",
          "approved_retrieval_packet",
          "coverage_report"
        ],
        "output": [
          "synthesis_context_packet"
        ]
      },
      "llm_call_boundary": {
        "description": "Fresh LLM call boundary that receives synthesis_context_packet and produces the user-facing assistant response",
        "components": [
          "provider payload construction",
          "structured or semi-structured response instructions",
          "retrieval basis preservation",
          "assistant response generation",
          "optional synthetic_node_candidate identification"
        ],
        "input": [
          "synthesis_context_packet"
        ],
        "output": [
          "assistant_response",
          "optional_synthetic_node_candidate",
          "raw_model_response",
          "llm_call_metadata"
        ]
      },
      "thread_state_delta_projection": {
        "description": "Final operation inside a state_perturbation that projects the completed turn artifacts into next_thread_state",
        "components": [
          "state_delta_generation",
          "active_concept_projection",
          "open_question_projection",
          "semantic_trajectory_projection",
          "retrieval_anchor_projection",
          "conversation_summary_projection",
          "thread_state_hash_generation"
        ],
        "input": [
          "prior_thread_state",
          "user_input",
          "perturbation_semantic_graph",
          "semantic_traversal_manifest",
          "retrieval_packet",
          "coverage_report",
          "assistant_response"
        ],
        "output": [
          "next_thread_state",
          "state_delta",
          "next_thread_state_hash"
        ]
      },
      "append_thread_ledger_record": {
        "description": "Operation that appends a hash-chained state_perturbation record to the thread_ledger",
        "components": [
          "hash prior_thread_state",
          "hash user_input",
          "hash perturbation artifacts",
          "hash assistant_response",
          "hash state_delta",
          "hash next_thread_state",
          "link parent_perturbation_hash",
          "write state_perturbation_record"
        ],
        "input": [
          "parent_perturbation_hash",
          "prior_thread_state_hash",
          "user_input_hash",
          "semantic_context_packet_hash",
          "semantic_traversal_manifest_hash",
          "retrieval_packet_hash",
          "coverage_report_hash",
          "assistant_response_hash",
          "state_delta_hash",
          "next_thread_state_hash"
        ],
        "output": [
          "state_perturbation_record",
          "state_perturbation_hash",
          "updated_thread_ledger"
        ]
      },
      "synthetic_node_promotion": {
        "description": "Optional write-back operation that persists selected synthesis output into latent_space as a synthetic_node",
        "components": [
          "promotion decision",
          "write_markdown_note_if_promoted",
          "assign frontmatter_tag identification",
          "chunk_promoted_node",
          "index_lexically",
          "embed_vector",
          "write_graph_provenance_edges",
          "write latent_space_update_record"
        ],
        "input": [
          "optional_synthetic_node_candidate",
          "assistant_response",
          "retrieval_packet",
          "semantic_traversal_manifest",
          "state_perturbation_hash",
          "originating_thread_id",
          "originating_message_id or turn_id"
        ],
        "output": [
          "optional_promoted_synthetic_node",
          "synthetic_node_chunk",
          "synthetic_node_lexical_record",
          "synthetic_node_vector_record",
          "synthetic_node_graph_edges",
          "latent_space_update_record"
        ]
      }
    }
  },
  "artifacts": {
    "user_input_event": {
      "description": "Recorded user_input submitted into a conversation_thread and used to trigger a state_perturbation",
      "created_by": "user_input",
      "consumed_by": [
        "conversation_thread",
        "state_perturbation",
        "semantic_context_extraction",
        "append_thread_ledger_record"
      ]
    },
    "prior_thread_state": {
      "description": "Current materialized thread_state loaded from the conversation_thread before the new state_perturbation begins",
      "created_by": "conversation_thread",
      "consumed_by": [
        "semantic_context_extraction",
        "synthesis_context_assembly",
        "thread_state_delta_projection",
        "append_thread_ledger_record"
      ]
    },
    "parent_perturbation_hash": {
      "description": "Hash pointer to the previous state_perturbation_record in the thread_ledger",
      "created_by": "thread_ledger",
      "consumed_by": [
        "state_perturbation",
        "append_thread_ledger_record"
      ]
    },
    "semantic_context_packet": {
      "description": "Structured packet produced from user_input and prior_thread_state, containing perturbation_nodes, contextual_salt_nodes, perturbation_semantic_graph, and semantic_coverage_target",
      "created_by": "semantic_context_extraction",
      "consumed_by": [
        "semantic_context_benchmark",
        "latent_space_activation",
        "synthesis_context_assembly",
        "thread_state_delta_projection",
